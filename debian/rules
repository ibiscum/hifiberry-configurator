#!/usr/bin/make -f

# Debian Trixie build configuration for dh_virtualenv
# The tests/ suite is pytest-style and depends on runtime modules
# (cryptography, etc.) that aren't present in the minimal build chroot; run
# it in CI/dev via pytest instead of at packaging time.
export PYBUILD_DISABLE=test
export PYBUILD_SYSTEM=pyproject
export PYBUILD_NAME=configurator


# Verbose output for debugging
export DH_VERBOSE=1

# Standard dh sequencer (no specific buildsystem needed - dh_virtualenv handles it)
%:
	dh $@ --with python3 --buildsystem=pybuild

# Skip default auto_clean (python-distutils removed in compat 12+)
# override_dh_auto_clean:
# 	@echo "Skipping auto_clean (handled by dh_virtualenv)"

# Skip default auto_configure (not needed)
# override_dh_auto_configure:
# 	@echo "Skipping auto_configure (not needed)"

# Skip default auto_build (dh_virtualenv handles everything)
# override_dh_auto_build:
# 	dh_auto_build
# 	@echo "Skipping auto_build (dh_virtualenv handles everything)"

# override_dh_auto_install:
# 	dh_auto_install

# Skip testing in the build environment (tests need cryptography, etc.)
# override_dh_auto_test:
# 	@echo "Skipping tests (should be run separately with pytest in dev environment)"

# Run dh_virtualenv to create the virtualenv with all dependencies
